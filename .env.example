# Copy this file to .env and fill in your own credentials.
# Do not commit .env with real API keys or passwords.

# OpenAI-compatible LLM and embedding provider
API_KEY="sk-your-api-key"
BASE_URL="https://api.siliconflow.cn/v1"
LLM_MODEL_ID="deepseek-ai/DeepSeek-V4-Flash"
EMBEDDING_MODEL_ID="BAAI/bge-m3"
EMBEDDING_DIM=1024

# OCR model
OCR_MODEL_ID="baidu/Unlimited-OCR"

# Start and use the configured local Ollama server in workflow/nodes.py.
# Set to false when using only the OpenAI-compatible provider above. When true,
# transient cloud failures automatically fall back to the local LLM.
GLOBLE_LOCAL_OPTIONAL=false

# Optional search provider used by TavilyMCPClient
TAVILY_API_KEY=""

# Zotero API
ZoteroID="your-zotero-user-or-group-id"
ZoteroKeys="your-zotero-api-key"

# Zotero WebDAV attachment sync
WEBDAV_HOSTNAME="https://example.com/dav/"
WEBDAV_LOGIN="your-webdav-username"
WEBDAV_PASSWD="your-webdav-password"

# Local data paths
MAINLY_SAVE_DIR="./database"
MILVUS_DIRECTORY="./database/Milvus"
MILVUS_DB_DIRECTORY="./database/Milvus/database.db"

# Milvus
MILVUS_URI="http://localhost:19530"
MILVUS_TOKEN=""
MILVUS_COLLECTION_NAME="arxiv_papers_hybrid"
MILVUS_HYBRID_RANKER="RRFRanker"
MILVUS_RRF_K=60
# Used only when MILVUS_HYBRID_RANKER="WeightedRanker".
MILVUS_HYBRID_WEIGHTS='[1.0, 0.5]'
NO_PROXY="localhost,127.0.0.1,::1"
no_proxy="localhost,127.0.0.1,::1"

PDF_SAVE_DIR="./database/Papers"
PDF_PARSER_SAVE_DIR="./database/parser"

# RAG chunking
CHUNK_SIZE=300
CHUNK_OVERLAP=50

# Optional local API serving
API_HOST="127.0.0.1"
API_PORT=8000
API_RELOAD=true

# Chainlit UI (read directly by UI.py)
CHAINLIT_PORT=8766
CHAINLIT_HEADLESS=0

# Logging and arXiv retry policy
LOG_LEVEL="INFO"
RATE_LIMIT=3.0
MAX_RETRIES=3
