# Copy this file to .env and fill in your own credentials.
# Do not commit .env with real API keys or passwords.

# LLM provider
LLM_API_KEY="sk-your-llm-api-key"
LLM_BASE_URL="https://api.siliconflow.cn/v1"
LLM_MODEL_ID="deepseek-ai/DeepSeek-V4-Flash"

# OCR / embedding models
OCR_MODEL_ID="baidu/Unlimited-OCR"
EMBEDDING_MODEL_ID=""

# Zotero API
ZoteroID="your-zotero-user-or-group-id"
ZoteroKeys="your-zotero-api-key"

# Zotero WebDAV attachment sync
WEBDAV_HOSTNAME="https://example.com/dav/"
WEBDAV_LOGIN="your-webdav-username"
WEBDAV_PASSWD="your-webdav-password"

# Optional search / external providers
TAVILY_API_KEY=""
SERPAPI_API_KEY=""
ALI_API_KEY=""

# Optional Qdrant cloud configuration
QDRANT_URL=""
QDRANT_API_KEY=""
QDRANT_COLLECTION="hello_agents_vectors"
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE="cosine"
QDRANT_TIMEOUT=30

# Optional Neo4j Aura configuration
NEO4J_URI=""
NEO4J_USERNAME=""
NEO4J_PASSWORD=""
NEO4J_DATABASE=""
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=60

# Chainlit UI
CHAINLIT_PORT=8766
CHAINLIT_HEADLESS=0

# Local data paths
MAINLY_SAVE_DIR="./database"
CHROMA_SAVE_DIR="./database/Chroma"
CHROMA_COLLECTION_NAME="arxiv_papers"
PDF_SAVE_DIR="./database/Papers"
PDF_PROCESS_SAVE_DIR="./database/pdf_ocr_results"

# RAG chunking
CHUNK_SIZE=3000
CHUNK_OVERLAP=500

# Optional local API serving
API_HOST="127.0.0.1"
API_PORT=8000
API_RELOAD=true

# Logging and arXiv retry policy
LOG_LEVEL="INFO"
RATE_LIMIT=3.0
MAX_RETRIES=3
